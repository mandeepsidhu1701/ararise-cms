# =============================================================================
# Ararise multi-tenant CMS — environment configuration
# Copy this file to ".env" and fill in real values.
# Docs: https://docs.silverstripe.org/en/5/getting_started/environment_management/
# =============================================================================

# --- Database (MySQL 8) ------------------------------------------------------
SS_DATABASE_CLASS="MySQLDatabase"
SS_DATABASE_SERVER="127.0.0.1"
SS_DATABASE_PORT="3306"
SS_DATABASE_USERNAME="root"
SS_DATABASE_PASSWORD=""
SS_DATABASE_NAME="credo_cms"

# --- Environment -------------------------------------------------------------
# "dev" | "test" | "live". Use "live" in production (cms.ararise.com).
SS_ENVIRONMENT_TYPE="dev"

# Base URL the CMS is served from. Locally under Laravel Herd this is the
# backend/public folder linked as a .test site, e.g. http://credo.test
SS_BASE_URL="http://credo.test"

# --- First admin login (created on dev/build in dev mode) --------------------
SS_DEFAULT_ADMIN_USERNAME="admin"
SS_DEFAULT_ADMIN_PASSWORD="password"

# --- Email -------------------------------------------------------------------
# Address contact-form notifications are sent *from*. The "to" address is each
# tenant's Settings.Email, configured in the CMS.
SS_SEND_ALL_EMAILS_FROM="no-reply@ararise.com"
# Optional: route all outbound mail to one inbox while testing.
# SS_SEND_ALL_EMAILS_TO="you@example.com"

# --- Misc --------------------------------------------------------------------
# Used to namespace caches / sessions across deployments.
# SS_ERROR_LOG="silverstripe.log"
